{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ImportDraft",
  "description": "Serialized entity draft payload passed between marketing generators and the app shell via localStorage.",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "character",
        "creature",
        "location",
        "item",
        "event",
        "faction",
        "note"
      ]
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "content": {
      "type": "string",
      "default": ""
    },
    "lore": {
      "type": "string"
    },
    "labels": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": ["imported-draft"]
    },
    "status": {
      "type": "string",
      "enum": ["active", "draft"],
      "default": "active"
    }
  },
  "required": ["type", "title", "content"]
}
