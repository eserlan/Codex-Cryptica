# Oracle Proxy Worker - Environment Configuration
# Copy this file to .env and fill in your values

# Cloudflare Account ID (optional, will prompt if not set)
# CLOUDFLARE_ACCOUNT_ID=your-account-id

# Cloudflare API Token (for CI/CD only, not needed for manual deploy)
# CLOUDFLARE_API_TOKEN=your-api-token

# Google Gemini API Key (MUST be set via `wrangler secret put`, not in .env)
# GEMINI_API_KEY is a secret and should NEVER be committed to .env

# Allowed Origins (optional, comma-separated list)
# Leave empty in wrangler.toml to use defaults
# ALLOWED_ORIGINS=https://codex-cryptica.com,https://staging.codex-cryptica.com
