{
  "name": "web",
  "private": true,
  "version": "0.27.14",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "prebuild": "node ../../scripts/generate-llms-full.mjs && bun ../../scripts/generate-sitemap.mjs",
    "build": "vite build && touch build/.nojekyll && node scripts/check-compiled-runes.js && node scripts/critical-css.mjs && cp build/index.html build/404.html",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:profile": "vitest run --reporter=verbose --silent=true",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "E2E_SMART=true playwright test --reporter=list,./tests/success-tracker-reporter.ts",
    "test:e2e:all": "playwright test --reporter=list,./tests/success-tracker-reporter.ts",
    "test:e2e:failed": "playwright test --reporter=list,./tests/success-tracker-reporter.ts --last-failed",
    "test:e2e:clear": "rm -f .e2e-success.json",
    "lint": "eslint .",
    "lint:types": "svelte-check --tsconfig ./tsconfig.json",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
  },
  "dependencies": {
    "@codex/ai-engine": "workspace:*",
    "@codex/audio-engine": "workspace:*",
    "@codex/canvas-engine": "workspace:*",
    "@codex/content-packs": "workspace:*",
    "@codex/events": "workspace:*",
    "@codex/family-engine": "workspace:*",
    "@codex/gdrive-sync": "workspace:*",
    "@codex/importer": "workspace:*",
    "@codex/oracle-engine": "workspace:*",
    "@codex/proposer": "workspace:*",
    "@codex/search-engine": "workspace:*",
    "@codex/search-orchestrator": "workspace:*",
    "@codex/sync-engine": "workspace:*",
    "@codex/vault-engine": "workspace:*",
    "@floating-ui/dom": "^1.7.6",
    "@google/generative-ai": "^0.24.1",
    "@tiptap/core": "^3.23.6",
    "@tiptap/extension-bubble-menu": "^3.23.6",
    "@tiptap/extension-floating-menu": "^3.23.6",
    "@tiptap/extension-link": "^3.23.6",
    "@tiptap/extension-table": "^3.23.6",
    "@tiptap/extension-table-cell": "^3.23.6",
    "@tiptap/extension-table-header": "^3.23.6",
    "@tiptap/extension-table-row": "^3.23.6",
    "@tiptap/pm": "^3.23.6",
    "@tiptap/starter-kit": "^3.23.6",
    "@types/gapi": "^0.0.47",
    "@types/gapi.auth2": "^0.0.61",
    "@types/gapi.client.drive": "^3.0.15",
    "@xyflow/svelte": "^1.5.2",
    "chronology-engine": "workspace:*",
    "comlink": "^4.4.2",
    "compromise": "^14.15.0",
    "cytoscape": "^3.33.4",
    "cytoscape-fcose": "^2.2.0",
    "dexie": "^4.4.2",
    "dice-engine": "workspace:*",
    "dompurify": "^3.4.2",
    "editor-core": "workspace:*",
    "flexsearch": "^0.8.212",
    "generator-engine": "workspace:*",
    "graph-engine": "workspace:*",
    "idb": "^8.0.3",
    "js-yaml": "^5.2.1",
    "lucide-svelte": "^1.0.1",
    "map-engine": "workspace:*",
    "markdown-it-task-lists": "^2.1.1",
    "marked": "^18.0.4",
    "marked-gfm-heading-id": "^4.1.4",
    "peerjs": "^1.5.5",
    "schema": "workspace:*",
    "svelte-tiptap": "^3.0.1",
    "tiptap-markdown": "^0.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@iconify-json/carbon": "^1.2.22",
    "@iconify-json/game-icons": "^1.2.3",
    "@iconify-json/heroicons": "^1.2.3",
    "@iconify-json/lucide": "^1.2.109",
    "@iconify-json/mdi": "^1.2.3",
    "@iconify-json/ph": "^1.2.2",
    "@iconify/tailwind4": "^1.2.3",
    "@playwright/test": "^1.60.0",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.60.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@types/google.accounts": "^0.0.18",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^26.1.0",
    "@vitest/coverage-v8": "^4.1.7",
    "critters": "^0.0.25",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "start-server-and-test": "^3.0.5",
    "svelte": "^5.55.9",
    "svelte-check": "^4.4.8",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
