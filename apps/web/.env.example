# Used for generating absolute URLs and client-side configuration in production.
VITE_PUBLIC_APP_URL=

# Optional: Google Gemini API Key for image generation
VITE_GOOGLE_IMAGEN_KEY=

# Optional: Shared Gemini API Key for 'Lite' mode.
# WARNING: This key will be visible in the client-side bundle.
# You MUST restrict this key to your domain in the Google Cloud Console
# (Credentials -> API Key -> Website Restrictions) to prevent unauthorized use.
VITE_SHARED_GEMINI_KEY=

# Optional: API Key for fetching public/shared files (Guest Mode).
# WARNING: This key will be visible in the client-side bundle.
# You MUST restrict this key to your domain in the Google Cloud Console.
VITE_GOOGLE_API_KEY=
