{
  "hooks": {
    "AfterAgent": [
      {
        "matcher": "<!-- GEMINI_CMD: speckit.implement -->",
        "hooks": [
          {
            "name": "speckit-completion-discord",
            "type": "command",
            "command": "/bin/bash -c \"./scripts/discord-notify.sh\"",
            "description": "Notify Discord after speckit implementation"
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "",
        "_note_GITHUB_PERSONAL_ACCESS_TOKEN": "Set this to a GitHub personal access token before using the GitHub MCP server (keep actual secrets out of version control)."
      }
    }
  }
}
