{
  "name": "codex-cryptica",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "bun": ">=1.3.0"
  },
  "scripts": {
    "build": "bun run --filter '*' build",
    "dev": "bun run --filter web dev",
    "lint": "bun run --filter '*' lint && bun run --filter '*' lint:types",
    "lint:fix": "bun run --filter '*' lint -- --fix",
    "test": "bun run --filter '*' test",
    "test:affected": "bun run --filter '*' test",
    "test:coverage": "bun run --filter '*' test:coverage",
    "test:e2e": "bun run --filter web test:e2e",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "commitlint": "commitlint --edit",
    "prepare": "husky",
    "assets:sync": "bun scripts/upload-images.mjs",
    "deploy:pages": "bun run build && wrangler pages deploy apps/web/build --project-name=codex-cryptica --branch=$(git rev-parse --abbrev-ref HEAD)",
    "deploy:oracle": "bash apps/workers/oracle-proxy/deploy.sh"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,svelte}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{md,json}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@emnapi/core": "^1.10.0",
    "@emnapi/runtime": "^1.10.0",
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "commitlint-config-gitmoji": "^2.3.1",
    "deepmerge": "^4.3.1",
    "js-yaml": "^4.1.1",
    "esbuild": "^0.28.0",
    "eslint": "10.4.0",
    "eslint-plugin-svelte": "^3.17.1",
    "gitmoji-cli": "^9.7.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prettier": "3.8.3",
    "prettier-plugin-svelte": "^4.0.1",
    "svelte-eslint-parser": "^1.6.1",
    "ts-morph": "^28.0.0",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.59.4",
    "vite": "^8.0.14",
    "vitefu": "^1.1.3",
    "wrangler": "^4.93.1"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@tiptap/extension-bubble-menu": "^3.23.6"
  }
}
