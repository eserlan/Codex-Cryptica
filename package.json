{
  "name": "codex-cryptica",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=11.0.0"
  },
  "packageManager": "npm@11.10.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint lint:types",
    "lint:fix": "turbo run lint -- --fix",
    "test": "turbo run test",
    "test:affected": "turbo run test --filter=[origin/staging]...",
    "test:coverage": "turbo run test:coverage",
    "test:e2e": "npm run test:e2e --workspace=web",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "commitlint": "commitlint --edit",
    "prepare": "husky",
    "assets:sync": "node scripts/upload-images.mjs",
    "deploy:pages": "npm run build --workspace=web && wrangler pages deploy apps/web/build --project-name=codex-cryptica --branch=$(git rev-parse --abbrev-ref HEAD)",
    "deploy:oracle": "bash apps/workers/oracle-proxy/deploy.sh"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,svelte}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{md,json}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@emnapi/core": "^1.10.0",
    "@emnapi/runtime": "^1.10.0",
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "commitlint-config-gitmoji": "^2.3.1",
    "deepmerge": "^4.3.1",
    "esbuild": "^0.28.0",
    "eslint": "10.2.1",
    "eslint-plugin-svelte": "^3.17.1",
    "gitmoji-cli": "^9.7.0",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "3.8.3",
    "prettier-plugin-svelte": "^3.5.1",
    "svelte-eslint-parser": "^1.6.0",
    "turbo": "^2.9.6",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.10",
    "vitefu": "^1.1.3",
    "wrangler": "^4.84.1"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@tiptap/extension-bubble-menu": "^3.22.4"
  }
}
